<body style="background:#111; color:#fff; font-family:sans-serif; text-align:right; padding:20px;" dir="rtl">
    <h1 style="color:gold;">🏛️ متجر b5 Store</h1>
    <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap:15px;">
        <% products.forEach(p=> { %>
            <div style="border:1px solid gold; padding:15px; border-radius:10px; background:#1a1a1a;">
                <h3>
                    <%= p.name %>
                </h3>
                <p style="color:yellow;">
                    <%= p.price.toLocaleString() %> كريديت
                </p>
                <button onclick="openPay('<%= p.name %>')"
                    style="background:gold; color:#000; border:none; padding:10px; width:100%; cursor:pointer; font-weight:bold;">شراء
                    الآن</button>
            </div>
            <% }) %>
    </div>

    <div id="payBox"
        style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); background:#222; padding:30px; border:2px solid gold; border-radius:15px;">
        <h3>إتمام شراء: <span id="pName"></span></h3>
        <form action="/order" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="productName" id="hName">
            <input type="text" name="discordName" placeholder="اسمك في الديسكورد" required
                style="width:100%; margin-bottom:10px;">
            <p>صورة التحويل:</p>
            <input type="file" name="img1" required>
            <p>صورة حسابك:</p>
            <input type="file" name="img2" required>
            <br><br>
            <button type="submit" style="background:green; color:white; padding:10px 20px;">إرسال الطلب</button>
            <button type="button" onclick="document.getElementById('payBox').style.display='none'">إلغاء</button>
        </form>
    </div>

    <script>
        function openPay(name) {
            document.getElementById('payBox').style.display = 'block';
            document.getElementById('pName').innerText = name;
            document.getElementById('hName').value = name;
        }
    </script>
</body>